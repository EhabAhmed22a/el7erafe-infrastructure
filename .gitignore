# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log
*.log

# Ignore any .tfvars files that are generated automatically
*.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
var.sh
variables.tf